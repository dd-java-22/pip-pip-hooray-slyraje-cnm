<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Title -->
    <TextView
      android:id="@+id/batch_title"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/label_batch_detail"
      android:textAppearance="?attr/textAppearanceHeadlineSmall"/>

    <!-- Summary heading -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:text="@string/label_summary"
      android:textAppearance="?attr/textAppearanceTitleMedium"/>

    <!-- Summary rows -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:orientation="vertical">

      <!-- Batch number -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_batch_number"/>

        <TextView
          android:id="@+id/batch_number_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Breed(s) -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_breeds"/>

        <TextView
          android:id="@+id/breeds_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Incubator -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_incubator"/>

        <TextView
          android:id="@+id/incubator_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Eggs set -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_eggs_set"/>

        <TextView
          android:id="@+id/eggs_set_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Viable count/rate -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_viable"/>

        <TextView
          android:id="@+id/viable_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Date set -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_date_set"/>

        <TextView
          android:id="@+id/date_set_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Lockdown date -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_lockdown_date"/>

        <TextView
          android:id="@+id/lockdown_date_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Expected hatch date -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="8dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_expected_hatch_date"/>

        <TextView
          android:id="@+id/expected_hatch_date_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

    </LinearLayout>

    <!-- Milestone heading -->
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:text="@string/label_milestones"
      android:textAppearance="?attr/textAppearanceTitleMedium"/>

    <!-- Milestone list -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:orientation="vertical">

      <!-- Day 7 -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_day_7_candling"/>

        <TextView
          android:id="@+id/day7_date"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Day 14 -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_day_14_candling"/>

        <TextView
          android:id="@+id/day14_date"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Day 18 / Lockdown -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_day_18_lockdown"/>

        <TextView
          android:id="@+id/day18_date"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

      <!-- Expected hatch -->
      <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="10dp">

        <TextView
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:text="@string/label_expected_hatch_day"/>

        <TextView
          android:id="@+id/hatch_date"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"/>
      </LinearLayout>

    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="24dp"
      android:orientation="vertical"
      android:paddingBottom="32dp">

      <Button
        android:id="@+id/bulk_candling_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_bulk_candling"/>

      <Button
      android:id="@+id/per_egg_candling_button"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="12dp"
      android:text="@string/action_per_egg_candling" />


    </LinearLayout>

  </LinearLayout>
</ScrollView>